{
  "private": true,
  "name": "superadmin",
  "packageManager": "pnpm@8.15.6",
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "verify": "pnpm run lint && pnpm run type-check && pnpm run test:ci && pnpm run build",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint --edit",
    "check:secrets": "secretlint \"**/*\" --maskSecrets",
    "check:staged-secrets": "node scripts/check-staged-secrets.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@secretlint/secretlint-rule-no-dotenv": "^13.0.2",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "secretlint": "^13.0.2",
    "sonarqube-scanner": "^4.3.6",
    "turbo": "^2.9.18"
  }
}
