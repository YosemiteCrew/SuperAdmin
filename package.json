{
  "private": true,
  "name": "superadmin",
  "packageManager": "pnpm@8.15.6",
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "verify": "pnpm run lint && pnpm run type-check && pnpm run test:ci && pnpm run build",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint --edit",
    "check:secrets": "secretlint \"**/*\" --maskSecrets",
    "check:staged-secrets": "node scripts/check-staged-secrets.js"
  },
  "pnpm": {
    "overrides": {
      "js-yaml@<4.2.0": ">=4.2.0 <5",
      "axios@>=1.0.0 <1.16.0": ">=1.16.0 <2",
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6 <5",
      "nodemailer@<=9.0.0": ">=9.0.1 <10",
      "turbo@<2.9.14": ">=2.9.14 <3",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3 <11",
      "postcss@<8.5.10": ">=8.5.10 <9"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@secretlint/secretlint-rule-no-dotenv": "^13.0.2",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "eslint": "^9.33.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "secretlint": "^11.3.0",
    "sonarqube-scanner": "^4.3.8",
    "turbo": "^2.5.0"
  }
}
