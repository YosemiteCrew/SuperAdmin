{
  "private": true,
  "name": "superadmin",
  "packageManager": "pnpm@8.15.6",
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "verify": "pnpm run lint && pnpm run type-check && pnpm run test:ci && pnpm run build",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint --edit",
    "check:secrets": "secretlint \"**/*\" --maskSecrets",
    "check:staged-secrets": "node scripts/check-staged-secrets.js"
  },
  "pnpm": {
    "overrides": {
      "js-yaml@<4.2.0": ">=4.2.0 <5",
      "axios@>=1.0.0 <1.16.0": ">=1.16.0 <2",
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6 <5",
      "nodemailer@<=9.0.0": ">=9.0.1 <10",
      "turbo@<2.9.14": ">=2.9.14 <3",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3 <11",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7 <10",
      "minimatch@<3.1.4": ">=3.1.4 <4",
      "postcss@<8.5.10": ">=8.5.10 <9",
      "ajv@>=4.0.0 <6.14.0": ">=6.14.0 <7",
      "flatted@<3.4.2": ">=3.4.2 <4",
      "brace-expansion@<1.1.13": ">=1.1.13 <2",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3 <3",
      "picomatch@>=2.0.0 <2.3.2": ">=2.3.2 <3",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4 <5",
      "@babel/core@<7.29.6": ">=7.29.6"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@secretlint/secretlint-rule-no-dotenv": "^13.0.2",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "secretlint": "^13.0.2",
    "sonarqube-scanner": "^4.3.8",
    "turbo": "^2.10.4"
  }
}
