// Prisma schema for the SuperAdmin panel.
// Run `pnpm --filter @superadmin/database run generate` after changes.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A GDPR data-subject rights request (access / erasure / rectification /
// objection). The controller must respond within one month, so dueAt is the
// statutory deadline; the row is the record that the request was handled.
model DataRequest {
  id           String    @id @default(cuid())
  subjectEmail String
  // 'access' | 'erasure' | 'rectification' | 'objection'
  type         String
  // 'received' | 'in_progress' | 'fulfilled' | 'rejected'
  status       String    @default("received")
  notes        String?   @db.Text
  receivedAt   DateTime  @default(now())
  // receivedAt + 30 days (the GDPR one-month response deadline).
  dueAt        DateTime
  fulfilledAt  DateTime?
  // super-admin userId who last actioned the request.
  handledBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([dueAt])
  @@index([subjectEmail])
}

// A person who has contacted Yosemite Crew (one row per email address).
// Leads are prospects, not accounts: linkedUserId is set only if/when the
// same email later matches a signed-up user. Consent captured here is the
// record of WHEN and FROM WHERE consent was given; Plunk remains the
// authority for live subscribed/unsubscribed state and delivery.
model ContactLead {
  id                String           @id @default(cuid())
  email             String           @unique
  name              String?
  company           String?
  newsletterConsent Boolean          @default(false)
  // When newsletter consent was captured, and the URL it came from.
  consentAt         DateTime?
  consentSource     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  requests          ContactRequest[]

  @@index([createdAt])
}

// A single contact-us submission. Many requests can belong to one lead.
model ContactRequest {
  id        String      @id @default(cuid())
  leadId    String
  lead      ContactLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  subject   String?
  message   String      @db.Text
  // Origin page, e.g. https://www.yosemitecrew.com/contact-us.
  sourceUrl String?
  // new | in_progress | closed
  status    String      @default("new")
  // super-admin userId who last changed the status.
  handledBy String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([leadId])
  @@index([status])
  @@index([createdAt])
}

// A person or device whose consent decisions we hold. Anonymous-first: keyed
// by the consent/device id captured at the cookie banner (e.g. a PostHog
// distinct_id), then linked to userId/email once the visitor authenticates.
model ConsentSubject {
  id        String         @id @default(cuid())
  consentId String         @unique
  userId    String?
  email     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  events    ConsentEvent[]

  @@index([userId])
  @@index([email])
}

// An immutable, append-only consent decision — the GDPR audit trail. Current
// state for a subject+category is the most recent event; nothing is ever
// updated or deleted here, so the full history of grants and withdrawals
// stays provable.
model ConsentEvent {
  id            String         @id @default(cuid())
  // Monotonic insertion order. `createdAt` is millisecond-precision, so two
  // decisions in the same category within one millisecond (double-fired banner,
  // grant-then-withdraw, concurrent writes) can't be ordered by time alone, and
  // cuid ids are not time-sortable. `seq` is the authoritative "which came last"
  // — deterministically resolving current-consent state.
  seq           BigInt         @default(autoincrement())
  subjectId     String
  subject       ConsentSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  // 'analytics' | 'marketing'
  category      String
  // true = consent granted, false = withdrawn.
  granted       Boolean
  // 'web' | 'mobile'
  source        String
  // Version of the privacy/cookie policy the subject consented to.
  policyVersion String?
  userAgent     String?
  createdAt     DateTime       @default(now())

  @@index([subjectId, category, seq])
  @@index([createdAt])
}

// ActivityPub federation license tokens.
// Issued by SuperAdmin to verified organizations so their self-hosted PIMS
// instances can federate with the Yosemite Crew cloud via the AP protocol.
model APLicenseToken {
  id             String    @id @default(cuid())
  orgId          String
  instanceDomain String
  // The signed RS256 JWT — stored so it can be re-served without re-signing.
  token          String    @db.Text
  keyId          String
  tier           String
  issuedAt       DateTime
  expiresAt      DateTime
  revokedAt      DateTime?
  // userId of the super-admin who revoked the token.
  revokedBy      String?

  @@index([orgId])
  @@index([instanceDomain])
  @@index([revokedAt])
}
