// Prisma schema for the SuperAdmin panel.
// Run `pnpm --filter @superadmin/database run generate` after changes.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A GDPR data-subject rights request (access / erasure / rectification /
// objection). The controller must respond within one month, so dueAt is the
// statutory deadline; the row is the record that the request was handled.
model DataRequest {
  id           String    @id @default(cuid())
  subjectEmail String
  // 'access' | 'erasure' | 'rectification' | 'objection'
  type         String
  // 'received' | 'in_progress' | 'fulfilled' | 'rejected'
  status       String    @default("received")
  notes        String?   @db.Text
  receivedAt   DateTime  @default(now())
  // receivedAt + 30 days (the GDPR one-month response deadline).
  dueAt        DateTime
  fulfilledAt  DateTime?
  // super-admin userId who last actioned the request.
  handledBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([dueAt])
  @@index([subjectEmail])
}

// ActivityPub federation license tokens.
// Issued by SuperAdmin to verified organizations so their self-hosted PIMS
// instances can federate with the Yosemite Crew cloud via the AP protocol.
model APLicenseToken {
  id             String    @id @default(cuid())
  orgId          String
  instanceDomain String
  // The signed RS256 JWT — stored so it can be re-served without re-signing.
  token          String    @db.Text
  keyId          String
  tier           String
  issuedAt       DateTime
  expiresAt      DateTime
  revokedAt      DateTime?
  // userId of the super-admin who revoked the token.
  revokedBy      String?

  @@index([orgId])
  @@index([instanceDomain])
  @@index([revokedAt])
}
