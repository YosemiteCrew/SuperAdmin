{
  "name": "admin",
  "private": true,
  "scripts": {
    "predev": "node ./scripts/clean-dev-cache.mjs",
    "dev": "next dev --turbopack",
    "dev:clean": "rm -rf .next .turbo && next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "node ./scripts/run-jest.mjs",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci",
    "test:coverage": "jest --coverage",
    "sonar": "node ./scripts/sonar.mjs",
    "sonar:full": "pnpm test:coverage && pnpm sonar"
  },
  "dependencies": {
    "@superadmin/database": "workspace:^",
    "clsx": "^2.1.1",
    "next": "15.5.18",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "5.3.0",
    "supertokens-auth-react": "^0.51.2",
    "supertokens-node": "^24.0.2",
    "supertokens-web-js": "^0.16.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@superadmin/types": "workspace:^",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "eslint-plugin-sonarjs": "^3.0.7",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
